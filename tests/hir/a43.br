// tests/hir/a43.br

mod a43;

var _0 = @static_assert match 12 {0...14 => 2, else => 1} == 2;

var _1 = @static_assert match 1111 {0...14 => 2, else => 1} == 2; // oops

var _2 = @static_assert match 11.11 {0...14 => 2, else => 1} == 2; // oops

var _3 = @static_assert match 14 {0...=14 => 2, else => 1} == 2;

var _4 = @static_assert match -14 {-14...=0 => 2, else => 1} == 2;

var _5 = @static_assert match -14 {0...=-14 => 2, else => 1} == 2;

var _6 = @static_assert match 0 {0...=0 => 2, else => 1} == 2;

var _7 = @static_assert match 10000000 {10000000 ...=0 => 2, else => 1} == 2;
