// tests/hir/a25.br

contract ComptGet {
    compt fn get(); // compt fns don't need an explicit return type in order to return a value
}


struct AnyCompt<T has ComptGet> {
    compt fn get() => T..get();
}

struct I32Transform<*fn(i32)->i32 F> has ComptGet {
    compt fn get() => F
}

compt fn double(i32 a) -> i32 => a + a

compt fn square(i32 a) -> i32 => a * a

compt fn cancel(i32 a) -> i32 => a - a

deftype Double = AnyCompt::I32Transform::(double);

deftype Square = AnyCompt::I32Transform::square;

deftype Cancel = AnyCompt::I32Transform::cancel;

compt Double a = {};

compt var _0 = (a.get())(12); // oops

var _1 = @static_assert Double..get()(12) == 24;

var _2 = @static_assert Square..get()(12) == 144;

var _3 = @static_assert Cancel..get()(12) == 1; // oops

var _4 = @static_assert Cancel..get()(12) == 0; // aha
