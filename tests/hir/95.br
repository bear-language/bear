// tests/hir/95.br

struct Bar {
    compt fn new() -> Self => Self{}
}

struct Foo<T> {
    compt T inst = T..new();  
}

struct Boo<T, i32 val> {
    T my_val;
    compt fn get() -> i32 => val
}

compt *fn()->Bar my_bar_fn = Bar..new;

compt Bar my_bar = my_bar_fn();

var _0 = @static_assert Bar{} == my_bar;

var _1 = @static_assert Bar{} != my_bar; // oops

compt *fn()->i32 my_fn = Boo..get::<i32,12>;

compt Bar bar = Foo..inst::Bar;

var _2 = @static_assert Bar{} == bar;

var _3 = @static_assert Bar{} != bar; // oops
