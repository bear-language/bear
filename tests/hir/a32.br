// tests/hir/a32.br

import "size.br";

mod test;

compt [&]i32 a = [1, 2, 3, 4, 5];

compt typeof(a) b = [1,2];

compt fn len<T>([&]T list) -> usize => list.len

compt usize both_len = len::<i32>(a) + len::<i32>(b);

compt [&]i32 c = a + b;

struct Foo {}

compt var d = ["123", "abc", 123, Foo{}];

compt var e = ['a', 'b', 'c'] + [1, 2, 3, 4, 5];

compt fn sum_list(var list) => sum_list_helper(list, 0)

compt fn sum_list_helper(var list, usize i) => { 
    0 if i >= list.len
        else list[i] + sum_list_helper(list, i + 1)
}

compt fn square(var i) => i*i

compt i32 f = sum_list([10,10,10,10,10,10] + [10] + [10,10,10,10,11]);

var _0 = @static_assert f == square(11);

compt [&mut]i32 _1 = [1, 2, 3]; // oops

fn first_elem<T>([&mut]T list) -> T => list[0]

compt var _2 = first_elem::<i32>([1, 2, 3]);

compt [&]i32 mut _3 = [1, 2, 3]; // oops
