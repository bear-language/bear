// tests/hir/97.br


struct Foo<T> {
    T inst;
    struct Barry<T> { // T is now shadowed
        struct T {} // oops
    }
    struct Bar <P> {
        hid Foo::T hid_inst;
        pub Barry::T pub_inst; // Barry with T now
        compt fn get() -> P => P..get() 
    }
    mod bar {
        struct Bar<M> {}
    }
}

var _0 = Foo..inst::i32; // oops

var _1 = Foo..bar..inst::i32; // oops (dne)

Foo..Bar<i32,i32> _2;

var _3 = @static_assert @same_type(Foo..Bar::<i32,i32>, Foo..Bar::<i32,i32>);
