// tests/hir/81.br

var _0 = @static_assert @inferable_as(i32, var);

var _1 = @static_assert @inferable_as(*i32, var);

var _2 = @static_assert @inferable_as(*i32, *var);

var _3 = @static_assert !@inferable_as(&i32, *var);

var _4 = @static_assert @inferable_as(*fn(**i32, &i32)->[&]i32, *fn(*var,&var)->[&]var);

var _5 = @static_assert !@inferable_as(*fn(**i32, &i32)->[&]i32, *fn(*var,&var)->[&]var); // oops

var _6 = @static_assert @inferable_as(*fn(**i32, &i32)->[&]i32, *fn(var,var)->var);

var _7 = @static_assert @inferable_as(*fn(var,var)->var, *fn(**i32, &i32)->[&]i32);


