// tests/hir/a28.br

variant Musketeers<T> {
    Three(T first, T second, T third),
    Two(T first, T second),
    One(T only),
    None
}

compt fn do(Musketeers::i32 a) -> i32 => match(a) {
    Three(var i) -> i,
    Two(var i) => i,
    One(var i) => i,
    None => 0,
}

deftype M = Musketeers::i32;

compt var a = M..One(42);

compt var b = do(a);

mod foo { // ~~~~~~~~~~~~~~~~~~~~~~~~~~

variant Foo {
    A(Bar a), // oops
    B,
    C,
    D,
}

variant Bar {
    A(Doo a),
    B,
}

variant Doo {
    A(Foo a),
    B,
    C,
}


compt var c = match(a) {
    Musketeers..Three(var i) -> i,
    Musketeers..Two(var i) => i,
    One(var i) => i,
    None => 0,
    Foo..B => 0, // oops
    123 => 0,
    b => 0,
};

} // mod foo ~~~~~~~~~~~~~~~~~~~~~~~~~~~
