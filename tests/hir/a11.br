// tests/hir/a11.br

compt bool check = @static_assert false;

var _0 = @warn "something_might_be_off";

var _1 = @note "hi";

var _2 = @note check, "it appears the check failed";

var _3 = @help true, "try to fix the check";

var _4 = @static_assert @help @help @help @help true, "help, i need somebody";

// some approaches: ~~~~~~~~~
struct DecayedSameType<A,B> {
    compt bool value = 
            @note(
                @err (!@same_type(decay A, decay B), @type_to_str(decay A) 
                    + " and " + @type_to_str(decay B) 
                    + " are not the same after being decayed"), 
                "the two passed-in types, A and B, should" 
                + " be the same type after decaying-away reference and type-aliases"
            );
}

struct DecayedSameTypeWithAssert<A,B> {
    compt bool a = @static_assert @same_type(decay A, decay B), "the two passed-in types, " 
            + @type_to_str(A) + " " + @type_to_str(B) + ", should" 
            + " be the same type after decaying-away reference and type-aliases, but were not";
    compt bool value = @note !a, "failed because, when decayed, " + @type_to_str(decay A) + " != " + @type_to_str(decay B);
}

struct Foo<T> {
    compt bool asdasdasd = asdasdasdasdasdasd; // oops
}

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

var _5 = DecayedSameType..value::<i32, &i32>; // fine

deftype MyInt = i64;

var _6 = DecayedSameType..value::<&i64, MyInt>; // fine

var _7 = DecayedSameType..value::<MyInt, i32>; // oops

var _8 = DecayedSameTypeWithAssert..value::<MyInt, *i32>; // oops

deftype MyFoo = Foo<i32>;
 
deftype MyFooTwo = Foo<MyFoo>; 
